{
  "info": {
    "name": "RentEverything API Workflow v3",
    "description": "Stateful, ordered, role-aware API test collection.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register (seed user)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Host\",\n  \"email\": \"testhost_{{$timestamp}}@rent.test\",\n  \"password\": \"Password123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "var payload = jsonData.data || jsonData;",
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "  if (payload.user && payload.user.email) { pm.environment.set('testUserEmail', payload.user.email); pm.environment.set('testUserPassword', 'Password123!'); }",
                  "  if (payload.accessToken) pm.environment.set('accessToken', payload.accessToken);",
                  "  if (payload.refreshToken) pm.environment.set('refreshToken', payload.refreshToken);",
                  "  if (payload.user && payload.user.id) pm.environment.set('userId', payload.user.id);",
                  "  pm.test('Register succeeded', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));",
                  "} else {",
                  "  pm.test('Register ok or user exists', () => pm.expect(pm.response.code).to.be.oneOf([200, 201, 400, 409]));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login (get tokens)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"emailOrPhone\": \"{{testUserEmail}}\",\n  \"password\": \"{{testUserPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Use registered email if available, else fall back to env loginEmail",
                  "var email = pm.environment.get('testUserEmail') || pm.environment.get('loginEmail');",
                  "var pass = pm.environment.get('testUserPassword') || pm.environment.get('loginPassword');",
                  "pm.environment.set('_loginEmail', email);",
                  "pm.environment.set('_loginPassword', pass);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login is successful', function() { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "var jsonData = pm.response.json();",
                  "var payload = jsonData.data || jsonData;",
                  "pm.test('Access token returned', function() { pm.expect(payload.accessToken).to.be.a('string'); });",
                  "pm.environment.set('accessToken', payload.accessToken);",
                  "pm.environment.set('refreshToken', payload.refreshToken);",
                  "if (payload.user && payload.user.id) pm.environment.set('userId', payload.user.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Refresh token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "refresh"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Refresh returns 200', function() { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "var payload = (pm.response.json().data || pm.response.json());",
                  "if (payload.accessToken) pm.environment.set('accessToken', payload.accessToken);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get my profile",
          "request": {
            "method": "GET",
            "header": [],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "me"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Profile returns 200', function() { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "var payload = (pm.response.json().data || pm.response.json());",
                  "if (payload.id) pm.environment.set('userId', payload.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
