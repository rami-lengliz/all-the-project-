# Application
NODE_ENV=development
PORT=3001

# CORS — comma-separated list of allowed frontend origins (no trailing slash)
# Production example: https://rentai.tn,https://www.rentai.tn
CORS_ORIGINS=http://localhost:3000,http://localhost:3001


# Database (Prisma format)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rental_platform?schema=public

# Legacy TypeORM variables (for reference, will be removed)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=rental_platform

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-in-production
REFRESH_TOKEN_EXPIRES_IN=7d


# ML Service
ML_SERVICE_URL=http://localhost:8000

# Upload
UPLOAD_DIR=uploads

# Commission
COMMISSION_PERCENTAGE=0.10

# Throttle
THROTTLE_TTL=60
THROTTLE_LIMIT=10
THROTTLE_AUTH_LIMIT=5
THROTTLE_BOOKING_LIMIT=10

# ── AI / LLM Provider ─────────────────────────────────────────────────────────
#
# AI_PROVIDER — selects the active completion backend.
#   Supported values (Week 6):
#     openai   → OpenAI Chat Completions API (default, currently the only option)
#   Coming next:
#     gemini   → Google Gemini Pro (will be added in Week 7)
#
#   If AI_PROVIDER is missing or set to an unknown value the app falls back
#   to "openai" silently — no crash, just a warning in the logs.
#
AI_PROVIDER=openai

# OpenAI credentials — required when AI_PROVIDER=openai
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini       # model used for all Chat Completions calls
AI_MAX_FOLLOWUPS=1          # max clarifying questions the AI search may ask (0 = always RESULT)

# Cloudinary (for image uploads in production — required on Railway)
CLOUDINARY_CLOUD_NAME=dzsa61iqo
CLOUDINARY_API_KEY=865899695783262
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ── PRODUCTION (Railway) ──────────────────────────────────────────────────────
# Set these as Railway env vars (NOT committed to git):
# DATABASE_URL=<railway-auto-provided>
# JWT_SECRET=<strong-64-char-random>
# REFRESH_TOKEN_SECRET=<strong-64-char-random>
# JWT_REFRESH_SECRET=<strong-64-char-random>
# CORS_ORIGINS=https://your-vercel-app.vercel.app
# NODE_ENV=production
# CLOUDINARY_API_SECRET=<your-real-secret>
