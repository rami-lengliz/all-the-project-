// This is the Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================
// User Model
// ===========================
model User {
  id            String   @id @default(uuid())
  name          String   @db.VarChar(255)
  email         String?  @unique @db.VarChar(255)
  phone         String?  @unique @db.VarChar(20)
  passwordHash  String   @map("password_hash") @db.VarChar(255)
  avatarUrl     String?  @db.VarChar(500)
  roles         String[] @default(["user"])
  isHost        Boolean  @default(false)
  verifiedEmail Boolean  @default(false)
  verifiedPhone Boolean  @default(false)
  ratingAvg     Decimal  @default(0) @db.Decimal(3, 2)
  ratingCount   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  suspendedAt   DateTime? @map("suspended_at")
  trustReviewedAt DateTime? @map("trust_reviewed_at")
  manualTrustTier String? @map("manual_trust_tier") @db.VarChar(50)

  // Relations
  listings               Listing[]
  bookingsAsRenter       Booking[]       @relation("RenterBookings")
  bookingsAsHost         Booking[]       @relation("HostBookings")
  reviewsWritten         Review[]        @relation("ReviewAuthor")
  reviewsReceived        Review[]        @relation("ReviewTarget")
  adminLogs              AdminLog[]
  paymentIntentsAsRenter PaymentIntent[] @relation("RenterPayments")
  paymentIntentsAsHost   PaymentIntent[] @relation("HostPayments")

  // Chat relations
  renterConversations Conversation[] @relation("RenterConversations")
  hostConversations   Conversation[] @relation("HostConversations")
  sentMessages        Message[]
  chatbotConversations ChatConversation[] @relation("UserChatbotConversations")
  chatbotActionConfirmations ChatbotActionConfirmation[] @relation("UserActionConfirmations")
  chatbotSecurityEvents ChatbotSecurityEvent[] @relation("UserChatbotSecurityEvents")
  payoutsAsHost       Payout[]       @relation("HostPayouts")
  categoryRequests    CategoryRequest[] @relation("RequesterCategoryRequests")

  @@index([email])
  @@index([phone])
  @@map("users")
}

// ===========================
// Category Request Model
// ===========================
enum CategoryRequestStatus {
  PENDING
  APPROVED
  REJECTED
  MERGED
}

model CategoryRequest {
  id              String   @id @default(uuid())
  requesterId     String   @map("requester_id")
  proposedName    String   @map("proposed_name") @db.VarChar(255)
  reason          String?  @db.Text
  status          CategoryRequestStatus @default(PENDING)
  adminNotes      String?  @map("admin_notes") @db.Text
  resolvedCategoryId String? @map("resolved_category_id")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  requester       User     @relation("RequesterCategoryRequests", fields: [requesterId], references: [id])
  resolvedCategory Category? @relation("ResolvedCategory", fields: [resolvedCategoryId], references: [id])

  @@map("category_requests")
}

// ===========================
// Category Model
// ===========================
model Category {
  id                String   @id @default(uuid())
  name              String   @db.VarChar(255)
  slug              String   @unique @db.VarChar(255)
  icon              String?  @db.VarChar(100)
  allowedForPrivate Boolean  @default(true) @map("allowed_for_private")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now())

  // Relations
  listings Listing[]
  categoryRequests CategoryRequest[] @relation("ResolvedCategory")

  @@index([slug], name: "idx_category_slug")
  @@index([isActive])
  @@map("categories")
}

// ===========================
// Listing Model
// ===========================
enum BookingType {
  DAILY
  SLOT
}

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  SUSPENDED
}

model Listing {
  id           String                               @id @default(uuid())
  hostId       String
  title        String                               @db.VarChar(255)
  description  String                               @db.Text
  categoryId   String
  images       String[]
  pricePerDay  Decimal                              @db.Decimal(10, 2)
  location     Unsupported("geometry(Point,4326)")?
  address      String                               @db.VarChar(500)
  rules        String?                              @db.Text
  availability Json?                                @db.JsonB
  isActive     Boolean                              @default(true)
  status       ListingStatus                        @default(PENDING_REVIEW)
  bookingType  BookingType                          @default(DAILY)
  deletedAt    DateTime?
  createdAt    DateTime                             @default(now())
  updatedAt    DateTime                             @updatedAt

  // Relations
  host              User               @relation(fields: [hostId], references: [id])
  category          Category           @relation(fields: [categoryId], references: [id])
  bookings          Booking[]
  reviews           Review[]
  conversations     Conversation[]
  slotConfiguration SlotConfiguration?

  @@index([pricePerDay])
  @@index([categoryId])
  @@index([isActive])
  @@index([status])
  @@index([deletedAt])
  @@map("listings")
}

// ===========================
// Booking Model
// ===========================
enum BookingStatus {
  pending
  confirmed
  paid
  completed
  cancelled
  rejected
}

enum DisputeStatus {
  NONE
  OPEN
  RESOLVED
}

model Booking {
  id        String   @id @default(uuid())
  listingId String
  renterId  String
  hostId    String
  startDate DateTime @db.Date
  endDate   DateTime @db.Date

  // Slot-specific fields (null for DAILY bookings)
  startTime DateTime? @db.Time
  endTime   DateTime? @db.Time

  totalPrice  Decimal       @db.Decimal(10, 2)
  commission  Decimal       @db.Decimal(10, 2)
  status      BookingStatus @default(pending)
  paid        Boolean       @default(false)
  paymentInfo Json?         @db.JsonB
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Immutable snapshot: captured at booking creation, never updated
  snapshotTitle          String?       @db.VarChar(255)
  snapshotPricePerDay    Decimal?      @db.Decimal(10, 2)
  snapshotCommissionRate Decimal?      @db.Decimal(5, 4)
  snapshotCurrency       String?       @default("TND") @db.VarChar(3)

  // Dispute
  disputeStatus DisputeStatus @default(NONE)

  // Relations
  listing       Listing        @relation(fields: [listingId], references: [id])
  renter        User           @relation("RenterBookings", fields: [renterId], references: [id])
  host          User           @relation("HostBookings", fields: [hostId], references: [id])
  review        Review?
  paymentIntent PaymentIntent?
  ledgerEntries LedgerEntry[]
  Conversation  Conversation[]

  @@index([startDate, endDate])
  @@index([status])
  @@index([listingId, startDate, startTime, endTime])
  @@map("bookings")
}

// ===========================
// Review Model
// ===========================
model Review {
  id           String   @id @default(uuid())
  bookingId    String   @unique
  authorId     String
  targetUserId String
  listingId    String
  rating       Int
  comment      String?  @db.Text
  createdAt    DateTime @default(now())

  // Relations
  booking    Booking @relation(fields: [bookingId], references: [id])
  author     User    @relation("ReviewAuthor", fields: [authorId], references: [id])
  targetUser User    @relation("ReviewTarget", fields: [targetUserId], references: [id])
  listing    Listing @relation(fields: [listingId], references: [id])

  @@index([targetUserId])
  @@map("reviews")
}

// ===========================
// AdminLog Model
// ===========================
model AdminLog {
  id        String   @id @default(uuid())
  action    String   @db.VarChar(255)
  actorId   String
  details   Json?    @db.JsonB
  createdAt DateTime @default(now())

  // Relations
  actor User @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([createdAt])
  @@map("admin_logs")
}

// ===========================
// PaymentIntent Model
// ===========================
enum PaymentIntentStatus {
  created
  authorized
  captured
  refunded
  cancelled
}

model PaymentIntent {
  id        String              @id @default(uuid())
  bookingId String              @unique
  renterId  String
  hostId    String
  amount    Decimal             @db.Decimal(10, 2)
  currency  String              @default("TND") @db.VarChar(3)
  status    PaymentIntentStatus @default(created)
  metadata  Json?               @db.JsonB
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  // Relations
  booking       Booking       @relation(fields: [bookingId], references: [id])
  renter        User          @relation("RenterPayments", fields: [renterId], references: [id])
  host          User          @relation("HostPayments", fields: [hostId], references: [id])
  ledgerEntries LedgerEntry[]

  @@index([bookingId])
  @@index([status])
  @@index([renterId])
  @@map("payment_intents")
}

// ===========================
// Chat Models
// ===========================
model Conversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Participants
  renterId String
  hostId   String
  renter   User   @relation("RenterConversations", fields: [renterId], references: [id])
  host     User   @relation("HostConversations", fields: [hostId], references: [id])

  // Optional: Link to booking or listing
  bookingId String?
  listingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id])
  listing   Listing? @relation(fields: [listingId], references: [id])

  // Messages in this conversation
  messages Message[]

  // Metadata
  lastMessageAt DateTime?

  @@unique([renterId, hostId, bookingId])
  @@index([renterId])
  @@index([hostId])
  @@index([bookingId])
  @@index([listingId])
  @@map("conversations")
}

model Message {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Content
  content String @db.Text

  // Sender
  senderId String
  sender   User   @relation(fields: [senderId], references: [id])

  // Conversation
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  // Read status
  readAt DateTime?

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
  @@map("messages")
}

// ===========================
// Slot Configuration Model
// ===========================
model SlotConfiguration {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Associated listing
  listingId String  @unique
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  // Slot settings
  slotDurationMinutes Int // e.g., 60 for 1-hour slots
  operatingHours      Json @db.JsonB // { "monday": { "start": "08:00", "end": "22:00" }, ... }
  minBookingSlots     Int  @default(1) // Minimum slots to book
  maxBookingSlots     Int? // Maximum slots per booking
  bufferMinutes       Int  @default(0) // Buffer time between bookings

  // Pricing
  pricePerSlot Decimal @db.Decimal(10, 2)

  @@index([listingId])
  @@map("slot_configurations")
}

// ===========================
// AI Search Log
// ===========================
model AiSearchLog {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())

  query        String
  lat          Float?
  lng          Float?
  radiusKm     Float?
  followUpAsked Boolean @default(false)
  mode         String   // 'FOLLOW_UP' | 'RESULT'
  filters      Json     @db.JsonB
  resultsCount Int      @default(0)

  @@index([createdAt])
  @@map("ai_search_logs")
}

// ===========================
// Ledger Models
// ===========================
enum LedgerEntryType {
  RENT_PAID
  COMMISSION
  HOST_PAYOUT_DUE
  REFUND
  ADJUSTMENT
  HOST_PAYOUT
}

enum LedgerDirection {
  CREDIT
  DEBIT
}

enum LedgerStatus {
  POSTED
  REVERSED
}

model LedgerEntry {
  id              String          @id @default(uuid())
  bookingId       String
  paymentIntentId String?
  actorId         String?
  type            LedgerEntryType
  direction       LedgerDirection
  amount          Decimal         @db.Decimal(10, 2)
  currency        String          @default("TND") @db.VarChar(3)
  status          LedgerStatus    @default(POSTED)
  reversedEntryId String?         @unique
  metadata        Json?           @db.JsonB
  createdAt       DateTime        @default(now())

  // Relations
  booking          Booking        @relation(fields: [bookingId], references: [id])
  paymentIntent    PaymentIntent? @relation(fields: [paymentIntentId], references: [id])
  reversedEntry    LedgerEntry?   @relation("Reversal", fields: [reversedEntryId], references: [id])
  reversedBy       LedgerEntry?   @relation("Reversal")
  payoutItem       PayoutItem?

  @@index([bookingId])
  @@index([paymentIntentId])
  @@index([type])
  @@index([createdAt])
  @@map("ledger_entries")
}

// ===========================
// Payout Models
// ===========================
enum PayoutStatus {
  PENDING
  PAID
  CANCELLED
}

model Payout {
  id        String       @id @default(uuid())
  hostId    String
  amount    Decimal      @db.Decimal(10, 2)
  currency  String       @default("TND") @db.VarChar(3)
  status    PayoutStatus @default(PENDING)
  method    String?      @db.VarChar(100)
  reference String?      @db.VarChar(255)
  notes     String?      @db.Text
  createdAt DateTime     @default(now())
  paidAt    DateTime?
  adminId   String?      // who created/approved

  host        User         @relation("HostPayouts", fields: [hostId], references: [id])
  items       PayoutItem[]

  @@index([hostId])
  @@index([status])
  @@index([createdAt])
  @@map("payouts")
}

model PayoutItem {
  id             String   @id @default(uuid())
  payoutId       String
  ledgerEntryId  String   @unique
  createdAt      DateTime @default(now())

  payout       Payout      @relation(fields: [payoutId], references: [id])
  ledgerEntry  LedgerEntry @relation(fields: [ledgerEntryId], references: [id])

  @@index([payoutId])
  @@map("payout_items")
}

// ===========================
// Chatbot Models
// ===========================
model ChatConversation {
  id        String   @id @default(uuid())
  userId    String
  title     String?  @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation("UserChatbotConversations", fields: [userId], references: [id])
  messages  ChatMessage[]
  summary   ChatConversationSummary?
  actionConfirmations ChatbotActionConfirmation[]
  securityEvents ChatbotSecurityEvent[]

  @@index([userId])
  @@map("chat_conversations")
}

model ChatConversationSummary {
  id                   String   @id @default(uuid())
  conversationId       String   @unique
  summaryText          String   @db.Text
  lastMessageIdCovered String?  @db.VarChar(255)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  conversation         ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("chat_conversation_summaries")
}

model ChatMessage {
  id             String   @id @default(uuid())
  conversationId String
  role           String   @db.VarChar(50) // user | assistant | tool | system
  content        String   @db.Text
  toolName       String?  @db.VarChar(255)
  toolPayload    Json?    @db.JsonB
  createdAt      DateTime @default(now())

  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
  @@map("chat_messages")
}

// ===========================
// Chatbot Mutation Flow
// ===========================
model ChatbotActionConfirmation {
  id             String   @id @default(uuid())
  userId         String
  conversationId String
  actionName     String   @db.VarChar(255)
  resourceType   String?  @db.VarChar(255)
  resourceId     String?  @db.VarChar(255)
  payload        Json?    @db.JsonB
  payloadHash    String   @db.VarChar(255)
  token          String   @unique @db.VarChar(255)
  status         String   @default("pending") @db.VarChar(50) // pending | confirmed | expired | consumed | cancelled
  createdAt      DateTime @default(now())
  expiresAt      DateTime
  consumedAt     DateTime?

  user           User             @relation("UserActionConfirmations", fields: [userId], references: [id])
  conversation   ChatConversation @relation(fields: [conversationId], references: [id])

  @@index([token])
  @@index([userId, conversationId])
  @@map("chatbot_action_confirmations")
}

// ===========================
// Chatbot Trust & Abuse Subsystem
// ===========================
model ChatbotSecurityEvent {
  id             String   @id @default(uuid())
  userId         String
  conversationId String?
  eventType      String   @db.VarChar(100) // e.g. 'rate_limit_exceeded', 'suspicious_payload', 'confirmation_replay'
  severity       String   @db.VarChar(50)  // 'low', 'medium', 'high', 'critical'
  reasonCode     String   @db.VarChar(255)
  metadata       Json?    @db.JsonB
  createdAt      DateTime @default(now())

  user           User              @relation("UserChatbotSecurityEvents", fields: [userId], references: [id])
  conversation   ChatConversation? @relation(fields: [conversationId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@map("chatbot_security_events")
}
