{
  "info": {
    "name": "RentEverything API Workflow v5 (Dual User)",
    "description": "Simulates a complete marketplace transaction between a Renter and a Host. Uses separate tokens to respect the 'cannot book own listing' rule and tests Host actions (confirming booking).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Renter Setup",
      "item": [
        {
          "name": "Register Renter",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Newman Renter\",\n  \"email\": \"renter_{{$timestamp}}@rent.test\",\n  \"password\": \"Password123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Register 200/201', function() { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "var payload = (pm.response.json().data || pm.response.json());",
                  "if (payload.accessToken) { pm.environment.set('renterToken', payload.accessToken); }",
                  "if (payload.user) { pm.environment.set('renterId', payload.user.id); }"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Host Setup",
      "item": [
        {
          "name": "Register Host",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Newman Host\",\n  \"email\": \"host_{{$timestamp}}@rent.test\",\n  \"password\": \"Password123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Register 200/201', function() { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "var payload = (pm.response.json().data || pm.response.json());",
                  "if (payload.accessToken) { pm.environment.set('hostToken', payload.accessToken); }",
                  "if (payload.user) {",
                  "  pm.environment.set('hostId', payload.user.id);",
                  "  pm.environment.set('_hostEmail', payload.user.email);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Become a host",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{hostToken}}"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"acceptTerms\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/me/become-host",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "me",
                "become-host"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Become host 200/201', function() { pm.expect(pm.response.code).to.be.oneOf([200, 201, 400]); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Re-login Host",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"emailOrPhone\": \"{{_hostEmail}}\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login 200/201', function() { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "var payload = (pm.response.json().data || pm.response.json());",
                  "if (payload.accessToken) { pm.environment.set('hostToken', payload.accessToken); }"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "3. Categories",
      "item": [
        {
          "name": "List categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/categories",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "categories"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var payload = (pm.response.json().data || pm.response.json());",
                  "var list = Array.isArray(payload) ? payload : (payload.items || []);",
                  "if(list.length > 0) pm.environment.set('categoryId', list[0].id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "4. Listings (Host)",
      "item": [
        {
          "name": "Create listing",
          "request": {
            "method": "POST",
            "header": [],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{hostToken}}"
                }
              ]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "Newman Mansion",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "A lovely place to stay",
                  "type": "text"
                },
                {
                  "key": "pricePerDay",
                  "value": "150",
                  "type": "text"
                },
                {
                  "key": "categoryId",
                  "value": "{{categoryId}}",
                  "type": "text"
                },
                {
                  "key": "availabilityType",
                  "value": "DAILY",
                  "type": "text"
                },
                {
                  "key": "bookingType",
                  "value": "DAILY",
                  "type": "text"
                },
                {
                  "key": "address",
                  "value": "123 Test St",
                  "type": "text"
                },
                {
                  "key": "latitude",
                  "value": "48.85",
                  "type": "text"
                },
                {
                  "key": "longitude",
                  "value": "2.35",
                  "type": "text"
                },
                {
                  "key": "images",
                  "type": "file",
                  "src": "./frontend/public/placeholder.png"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/listings",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "listings"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "if(!pm.environment.get('categoryId')) pm.execution.skipRequest();"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Listing created', function() { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "var payload = (pm.response.json().data || pm.response.json());",
                  "var id = payload.listing ? payload.listing.id : payload.id;",
                  "if(id) pm.environment.set('listingId', id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "5. Bookings (Renter & Host)",
      "item": [
        {
          "name": "Create booking (Renter)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{renterToken}}"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"listingId\": \"{{listingId}}\",\n  \"startDate\": \"2026-07-01\",\n  \"endDate\": \"2026-07-05\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/bookings",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "bookings"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "if(!pm.environment.get('listingId')) pm.execution.skipRequest();"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Booking created', function() { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "var p = (pm.response.json().data || pm.response.json());",
                  "if(p.id) pm.environment.set('bookingId', p.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Confirm booking (Host)",
          "request": {
            "method": "PATCH",
            "header": [],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{hostToken}}"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/bookings/{{bookingId}}/confirm",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "bookings",
                "{{bookingId}}",
                "confirm"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "if(!pm.environment.get('bookingId')) pm.execution.skipRequest();"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Confirmed', function() { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "6. Payments (Renter)",
      "item": [
        {
          "name": "Authorize payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{renterToken}}"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentMethod\": \"card\",\n  \"currency\": \"USD\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/payments/booking/{{bookingId}}/authorize",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "payments",
                "booking",
                "{{bookingId}}",
                "authorize"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "if(!pm.environment.get('bookingId')) pm.execution.skipRequest();"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Paid', function() { pm.expect(pm.response.code).to.be.oneOf([200, 201, 400, 409]); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "7. Reviews (Renter)",
      "item": [
        {
          "name": "Leave a review",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{renterToken}}"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"listingId\": \"{{listingId}}\",\n  \"bookingId\": \"{{bookingId}}\",\n  \"rating\": 5,\n  \"comment\": \"Amazing place!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/reviews",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "reviews"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "if(!pm.environment.get('bookingId')) pm.execution.skipRequest();"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Reviewed', function() { pm.expect(pm.response.code).to.be.oneOf([200, 201, 400, 409]); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "8. Chat (Renter & Host)",
      "item": [
        {
          "name": "Send message (Renter to Host)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{renterToken}}"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"otherUserId\": \"{{hostId}}\",\n  \"listingId\": \"{{listingId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/chat/conversations",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "chat",
                "conversations"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "if(!pm.environment.get('hostId') || !pm.environment.get('listingId')) pm.execution.skipRequest();"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Chat started', function() { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "var p = (pm.response.json().data || pm.response.json());",
                  "if(p.id) pm.environment.set('conversationId', p.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Read message (Host)",
          "request": {
            "method": "GET",
            "header": [],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{hostToken}}"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/chat/conversations/{{conversationId}}/messages",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "chat",
                "conversations",
                "{{conversationId}}",
                "messages"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "if(!pm.environment.get('conversationId')) pm.execution.skipRequest();"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Host read chat', function() { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ]
}