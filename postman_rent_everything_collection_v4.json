{
  "info": {
    "name": "RentEverything API Workflow v4",
    "description": "Stateful, ordered, rate-limit-aware API test collection. Register returns tokens so Login is skipped in the main path.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register + capture tokens",
          "description": "Register also returns accessToken + refreshToken. This avoids an extra Login call and prevents hitting the 5-req/min auth throttle.",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Newman Host\",\n  \"email\": \"newmanhost_{{$timestamp}}@rent.test\",\n  \"password\": \"Password123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Register returns 200 or 201', function() {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "var payload = (pm.response.json().data || pm.response.json());",
                  "if (payload.accessToken) {",
                  "  pm.environment.set('accessToken', payload.accessToken);",
                  "  pm.environment.set('refreshToken', payload.refreshToken);",
                  "}",
                  "if (payload.user) {",
                  "  pm.environment.set('userId', payload.user.id);",
                  "  pm.environment.set('_regEmail', payload.user.email);",
                  "  pm.environment.set('_regPassword', 'Password123!');",
                  "}",
                  "pm.test('Access token captured', function() {",
                  "  pm.expect(pm.environment.get('accessToken')).to.be.a('string').and.have.length.above(10);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get my profile",
          "request": {
            "method": "GET",
            "header": [],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "me"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Profile returns 200 or 201', function() {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "var payload = (pm.response.json().data || pm.response.json());",
                  "if (payload.id) pm.environment.set('userId', payload.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Host Setup",
      "item": [
        {
          "name": "Become a host",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"acceptTerms\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/me/become-host",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "me",
                "become-host"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Become host returns 200/201 or already host 400', function() {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201, 400]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Re-login for HOST-role JWT (wait 65s if throttled)",
          "description": "Auth endpoint is throttled at 5 req/min. This re-login is needed to receive a JWT with role=HOST. If you see 429, wait 60 seconds and re-run from this step only.",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"emailOrPhone\": \"{{_regEmail}}\",\n  \"password\": \"{{_regPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Auth is throttled at 5 req/min.",
                  "// Register already used 1 call. This re-login is call #2 within the minute.",
                  "// We add a 1s pause to create natural spacing — Newman --delay-request handles the rest.",
                  "// If still 429, run only this folder after 60s."
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Re-login returns 200 or 201 (not 429)', function() {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "if (pm.response.code === 429) {",
                  "  pm.test('THROTTLED - wait 60s then re-run Host Setup folder', function() {",
                  "    pm.expect(pm.response.code).to.not.equal(429);",
                  "  });",
                  "} else {",
                  "  var payload = (pm.response.json().data || pm.response.json());",
                  "  if (payload.accessToken) {",
                  "    pm.environment.set('accessToken', payload.accessToken);",
                  "    pm.environment.set('refreshToken', payload.refreshToken);",
                  "  }",
                  "  pm.test('User is now a host', function() {",
                  "    pm.expect(payload.user.isHost).to.eql(true);",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
